# ── Database (Railway Postgres) ──
# Railway → your Postgres service → Connect → Postgres Connection URL
DATABASE_URL=postgresql://user:password@host.proxy.rlwy.net:PORT/railway

# ── Auth ──
# Long random string used to sign session JWTs. Generate: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-secret
# Public base URL (used to build OAuth redirects, magic links + Stripe redirects)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Google sign-in (optional — "Continue with Google" shows only when both are set) ──
# Google Cloud Console → APIs & Services → Credentials → OAuth client ID (Web application).
# Authorized redirect URI must be: <NEXT_PUBLIC_BASE_URL>/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Email (optional — magic links + receipts). If absent, dev logs the link to the console ──
RESEND_API_KEY=
EMAIL_FROM=StudioMVP <hello@studiomvp.co.uk>

# ── Stripe (optional — checkout is disabled until set) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Project images on Cloudflare R2 (optional) ──
# When set, showcase/case-study images are served from R2 instead of Unsplash.
# S3_PUBLIC_URL doubles as the app's public image base (no NEXT_PUBLIC_ copy needed).
# Create an R2 bucket + an S3 API token in the Cloudflare dashboard.
S3_BUCKET_NAME=
S3_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://pub-<hash>.r2.dev
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
# Optional explicit override for the public image base (defaults to S3_PUBLIC_URL):
# NEXT_PUBLIC_ASSET_BASE_URL=https://assets.studiomvp.co.uk