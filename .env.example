# ── Database (Railway Postgres) ──
# Railway → your Postgres service → Connect → Postgres Connection URL
DATABASE_URL=postgresql://user:password@host.proxy.rlwy.net:PORT/railway

# ── Auth ──
# Long random string used to sign session JWTs. Generate: openssl rand -base64 48
SESSION_SECRET=change-me-to-a-long-random-secret
# Public base URL (used to build magic links + Stripe redirects)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ── Email (optional — magic links + receipts). If absent, dev logs the link to the console ──
RESEND_API_KEY=
EMAIL_FROM=StudioMVP <hello@studiomvp.co.uk>

# ── Stripe (optional — checkout is disabled until set) ──
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
